# ============================================================================
# Knox_Knox / 해일미리 — Next.js 검수 콘솔 환경변수 템플릿
# ----------------------------------------------------------------------------
# 1) 이 파일을 복사해 console/.env.local 을 만듭니다.
# 2) 아래 빈 값을 실제 값으로 채웁니다.
# 3) .env.local 은 .gitignore 에 포함되어야 합니다(이 example 파일만 커밋).
# ============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────
# Supabase 프로젝트 Settings → API 에서 확인
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service Role Key — 서버사이드(API Route)에서만 사용. 절대 클라이언트 노출 금지.
SUPABASE_SERVICE_ROLE_KEY=

# ── n8n (워크플로우 서버) ─────────────────────────────────────────────────
# 워크플로우 베이스 URL. /webhook 또는 /webhook-test 경로는 코드에서 붙임.
N8N_WEBHOOK_BASE_URL=https://wontaeryu.app.n8n.cloud

# ── 내부 API 보안 ─────────────────────────────────────────────────────────
# n8n → /api/console-update 호출 시 헤더 x-console-secret 으로 검증할 값.
# openssl rand -hex 32 로 랜덤 생성 권장.
CONSOLE_API_SECRET=

# ── 배포 환경 ─────────────────────────────────────────────────────────────
# 로컬: http://localhost:3000 / 운영: Vercel 도메인
NEXT_PUBLIC_APP_URL=http://localhost:3000
